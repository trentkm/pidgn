rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isHouseholdMember(householdId) {
      return isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    // ─── users/{userId} ─────────────────────────────────────

    match /users/{userId} {
      // Users can only read their own document
      allow read: if isOwner(userId);

      // Users can create their own document (uid must match)
      allow create: if isOwner(userId);

      // Users can update their own document
      allow update: if isOwner(userId);

      // No deletes from client
      allow delete: if false;
    }

    // ─── households/{householdId} ───────────────────────────

    match /households/{householdId} {
      // Household members can read the household doc
      allow read: if isHouseholdMember(householdId);

      // Any authenticated user can create a household
      // (server handles adding them as the first member via Admin SDK)
      allow create: if isAuthenticated();

      // Only members can update the household doc
      allow update: if isHouseholdMember(householdId);

      // No deletes from client
      allow delete: if false;

      // ─── households/{householdId}/members/{userId} ──────

      match /members/{userId} {
        // Household members can read member subdocs
        allow read: if isHouseholdMember(householdId);

        // Writes are handled by Admin SDK (server-side)
        allow write: if false;
      }

      // ─── households/{householdId}/mailbox/{messageId} ───

      match /mailbox/{messageId} {
        // Household members can read their mailbox
        allow read: if isHouseholdMember(householdId);

        // Writes are handled by Admin SDK (server-side)
        allow write: if false;
      }
    }

    // ─── contacts/{householdId}/connected/{targetHouseholdId} ─

    match /contacts/{householdId}/connected/{targetHouseholdId} {
      // Household members can read their contacts
      allow read: if isHouseholdMember(householdId);

      // Writes are handled by Admin SDK (server-side)
      allow write: if false;
    }
  }
}
